@page "/Account/InitialSetup"
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using DcScrapingPlatform.Models
@using DcScrapingPlatform.Data
@using DcScrapingPlatform.Services
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@inject UserManager<ApplicationUser> UserManager
@inject ApplicationDbContext DbContext
@inject IEncryptionService EncryptionService
@inject NavigationManager NavigationManager
@inject ILogger<InitialSetup> Logger

<PageTitle>初期設定 - DC資産管理</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-16">
    <MudText Typo="Typo.h4" Align="Align.Center" Class="mb-4">初期セットアップ</MudText>
    <MudAlert Severity="Severity.Info" Class="mb-8">
        サービスを開始するために、DCサイトのログイン情報、またはGoogleスプレッドシートIDのいずれか（あるいは両方）を設定してください。
    </MudAlert>

    <EditForm Model="Input" OnValidSubmit="SaveSettings" FormName="initial-setup" method="post">
        <DataAnnotationsValidator />
        
        <MudGrid>
            <MudItem xs="12" md="6">
                <MudCard Elevation="4" Class="pa-6">
                    <MudText Typo="Typo.h6" Class="mb-4"><MudIcon Icon="@Icons.Material.Filled.AccountBalance" Class="mr-2"/>DCサイト連携設定</MudText>
                    <MudText Typo="Typo.body2" Class="mb-4">企業型DCの資産情報を自動取得するためのログイン情報を入力してください。</MudText>
                    
                    <MudTextField @bind-Value="Input.DcLoginId" Label="ログインID" Variant="Variant.Outlined" FullWidth="true" Class="mb-4" />
                    <MudTextField @bind-Value="Input.DcPassword" Label="パスワード" Variant="Variant.Outlined" InputType="InputType.Password" FullWidth="true" />
                </MudCard>
            </MudItem>

            <MudItem xs="12" md="6">
                <MudCard Elevation="4" Class="pa-6">
                    <MudText Typo="Typo.h6" Class="mb-4"><MudIcon Icon="@Icons.Custom.FileFormats.FileExcel" Class="mr-2"/>外部連携設定</MudText>
                    <MudText Typo="Typo.body2" Class="mb-4">取得したデータを保存する Google スプレッドシートの ID を入力してください。</MudText>
                    
                    <MudTextField @bind-Value="Input.SpreadsheetId" Label="スプレッドシート ID" Variant="Variant.Outlined" FullWidth="true" HelperText="ブラウザのURLから取得できるIDを入力してください" />
                </MudCard>
            </MudItem>

            <MudItem xs="12">
                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <MudAlert Severity="Severity.Error" Class="mt-4">@errorMessage</MudAlert>
                }
                <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" Size="Size.Large" Class="mt-8">
                    設定を保存して開始
                </MudButton>
            </MudItem>
        </MudGrid>
    </EditForm>
</MudContainer>

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthenticationStateTask { get; set; }

    [SupplyParameterFromForm]
    public SetupInputModel Input { get; set; } = new();

    private string? errorMessage;

    protected override void OnInitialized() => Input ??= new();

    private async Task SaveSettings()
    {
        errorMessage = null;

        // 相関バリデーション: どちらか一方が必須
        bool hasDcInfo = !string.IsNullOrWhiteSpace(Input.DcLoginId) && !string.IsNullOrWhiteSpace(Input.DcPassword);
        bool hasSpreadsheetInfo = !string.IsNullOrWhiteSpace(Input.SpreadsheetId);

        if (!hasDcInfo && !hasSpreadsheetInfo)
        {
            errorMessage = "DCサイト連携情報（IDとパスワード両方）、またはスプレッドシートIDの少なくとも一方を入力してください。";
            return;
        }

        if (AuthenticationStateTask is null) return;
        var authState = await AuthenticationStateTask;
        var user = await UserManager.GetUserAsync(authState.User);
        if (user is null)
        {
            errorMessage = "ユーザー情報の取得に失敗しました。再度ログインしてください。";
            return;
        }

        using var transaction = await DbContext.Database.BeginTransactionAsync();
        try
        {
            // 1. DC 連携情報の保存
            if (hasDcInfo)
            {
                var (encryptedId, iv) = EncryptionService.Encrypt(Input.DcLoginId!);
                var encryptedPwd = EncryptionService.Encrypt(Input.DcPassword!, iv);

                var credential = await DbContext.DcCredentials.FirstOrDefaultAsync(c => c.UserId == user.Id);
                if (credential == null)
                {
                    credential = new DcCredential { UserId = user.Id };
                    DbContext.DcCredentials.Add(credential);
                }

                credential.EncryptedId = encryptedId;
                credential.EncryptedPassword = encryptedPwd;
                credential.Iv = iv; 
                credential.UpdatedAt = DateTime.UtcNow;
            }

            // 2. プロフィール（SpreadsheetId）の保存
            if (hasSpreadsheetInfo)
            {
                var profile = await DbContext.Profiles.FirstOrDefaultAsync(p => p.UserId == user.Id);
                if (profile == null)
                {
                    profile = new Profile { UserId = user.Id };
                    DbContext.Profiles.Add(profile);
                }
                profile.SpreadsheetId = Input.SpreadsheetId;
                profile.UpdatedAt = DateTime.UtcNow;
            }

            await DbContext.SaveChangesAsync();
            await transaction.CommitAsync();

            Logger.LogInformation("User {UserId} completed initial setup.", user.Id);
            NavigationManager.NavigateTo("/");
        }
        catch (Exception ex)
        {
            await transaction.RollbackAsync();
            Logger.LogError(ex, "Error saving initial setup for user {UserId}", user.Id);
            errorMessage = "設定の保存中にエラーが発生しました。時間を置いて再度お試しください。";
        }
    }

    public class SetupInputModel
    {
        [Display(Name = "DCログインID")]
        public string? DcLoginId { get; set; }

        [Display(Name = "DCパスワード")]
        [DataType(DataType.Password)]
        public string? DcPassword { get; set; }

        [Display(Name = "スプレッドシートID")]
        public string? SpreadsheetId { get; set; }
    }
}
