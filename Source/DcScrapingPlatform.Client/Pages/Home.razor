@page "/"

<PageTitle>Dashboard - DcScrapingPlatform</PageTitle>

<MudText Typo="Typo.h3" Class="mb-6">Dashboard</MudText>

<MudGrid>
    <MudItem xs="12" sm="6" md="4">
        <MudPaper Elevation="2" Class="pa-4" Style="height: 200px;">
            <MudText Typo="Typo.h6">Total Balance</MudText>
            <MudText Typo="Typo.h3" Color="Color.Primary" Class="mt-4">¥4,250,000</MudText>
            <MudText Typo="Typo.body2" Class="mt-2" Color="Color.Success">+¥120,000 (Last Month)</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="6" md="4">
        <MudPaper Elevation="2" Class="pa-4" Style="height: 200px;">
            <MudText Typo="Typo.h6">Profit / Loss</MudText>
            <MudText Typo="Typo.h3" Color="Color.Secondary" Class="mt-4">+¥850,000</MudText>
            <MudText Typo="Typo.body2" Class="mt-2">+25.0% (All Time)</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="6" md="4">
        <MudPaper Elevation="2" Class="pa-4" Style="height: 200px;">
            <MudText Typo="Typo.h6">Next Fetch</MudText>
            <MudText Typo="Typo.h3" Class="mt-4">Tomorrow</MudText>
            <MudText Typo="Typo.body2" Class="mt-2">Scheduled at 03:00 AM</MudText>
        </MudPaper>
    </MudItem>

    <MudItem xs="12" md="8">
        <MudPaper Elevation="2" Class="pa-4">
            <MudText Typo="Typo.h6" Class="mb-4">Asset Growth</MudText>
            <MudChart T="double" ChartType="ChartType.Line" ChartSeries="@_series" XAxisLabels="@_xAxisLabels" Width="100%" Height="350px" />
        </MudPaper>
    </MudItem>
    <MudItem xs="12" md="4">
        <MudPaper Elevation="2" Class="pa-4">
            <MudText Typo="Typo.h6" Class="mb-4">Portfolio Allocation</MudText>
            <MudChart T="double" ChartType="ChartType.Donut" Data="@_donutData" Labels="@_donutLabels" Width="100%" Height="300px" />
        </MudPaper>
    </MudItem>

    <MudItem xs="12">
        <MudPaper Elevation="2" Class="pa-4">
            <div class="d-flex align-center justify-space-between mb-4">
                <MudText Typo="Typo.h6">Scraping Activities</MudText>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.PlayArrow" OnClick="RunScraping">
                    Run Scraping Now
                </MudButton>
            </div>
            <MudDataGrid Items="@_logs" Hover="true" Bordered="false" Striped="true" FixedHeader="true" Height="300px">
                <Columns>
                    <PropertyColumn Property="x => x.Target" Title="Target" />
                    <TemplateColumn Title="Status">
                        <CellTemplate>
                            <MudChip T="string" Color="@GetStatusColor(context.Item.Status)" Size="Size.Small" Variant="Variant.Text">
                                @context.Item.Status
                            </MudChip>
                        </CellTemplate>
                    </TemplateColumn>
                    <PropertyColumn Property="x => x.StartedAt" Title="Started At" Format="yyyy-MM-dd HH:mm" />
                    <PropertyColumn Property="x => x.FinishedAt" Title="Finished At" Format="yyyy-MM-dd HH:mm" />
                    <TemplateColumn Title="Actions" CellClass="d-flex justify-end">
                        <CellTemplate>
                            <MudIconButton Icon="@Icons.Material.Filled.Info" Size="Size.Small" />
                        </CellTemplate>
                    </TemplateColumn>
                </Columns>
            </MudDataGrid>
        </MudPaper>
    </MudItem>

    <MudItem xs="12">
        <MudPaper Elevation="2" Class="pa-4">
            <MudText Typo="Typo.h6" Class="mb-4">Portfolio Holdings</MudText>
            <MudSimpleTable Style="overflow-x: auto;">
                <thead>
                    <tr>
                        <th>Fund Name</th>
                        <th>Category</th>
                        <th>Balance</th>
                        <th>Profit/Loss</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>Global Equity Fund</td>
                        <td>Equity</td>
                        <td>¥2,100,000</td>
                        <td><MudText Color="Color.Success">+¥450,000</MudText></td>
                    </tr>
                    <tr>
                        <td>Japan Debt Fund</td>
                        <td>Bond</td>
                        <td>¥1,200,000</td>
                        <td><MudText Color="Color.Error">-¥12,000</MudText></td>
                    </tr>
                    <tr>
                        <td>REIT Balanced</td>
                        <td>Real Estate</td>
                        <td>¥950,000</td>
                        <td><MudText Color="Color.Success">+¥85,000</MudText></td>
                    </tr>
                </tbody>
            </MudSimpleTable>
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    private List<ChartSeries<double>> _series = new List<ChartSeries<double>>()
    {
        new ChartSeries<double>() { Name = "Balance", Data = new double[] { 3500000, 3620000, 3750000, 3810000, 4050000, 4250000 } }
    };
    private string[] _xAxisLabels = { "Jan", "Feb", "Mar", "Apr", "May", "Jun" };

    private double[] _donutData = { 50, 25, 25 };
    private string[] _donutLabels = { "Equity", "Bond", "Real Estate" };

    private List<ScrapingLogSummary> _logs = new()
    {
        new ScrapingLogSummary { Target = "UFJ DC Asset", Status = "Success", StartedAt = DateTime.Now.AddDays(-1), FinishedAt = DateTime.Now.AddDays(-1).AddMinutes(2) },
        new ScrapingLogSummary { Target = "UFJ DC Asset", Status = "Error", StartedAt = DateTime.Now.AddDays(-2), FinishedAt = DateTime.Now.AddDays(-2).AddMinutes(1) },
        new ScrapingLogSummary { Target = "UFJ DC Asset", Status = "Success", StartedAt = DateTime.Now.AddDays(-3), FinishedAt = DateTime.Now.AddDays(-3).AddMinutes(2) }
    };

    private Color GetStatusColor(string status) => status switch
    {
        "Success" => Color.Success,
        "Error" => Color.Error,
        "Running" => Color.Info,
        _ => Color.Default
    };

    private void RunScraping()
    {
        // 実際のトリガーは API を介して行うが、UIプロトタイプとしてメッセージを表示
    }

    public class ScrapingLogSummary
    {
        public string Target { get; set; } = string.Empty;
        public string Status { get; set; } = string.Empty;
        public DateTime StartedAt { get; set; }
        public DateTime? FinishedAt { get; set; }
    }
}
