@page "/"

<PageTitle>ダッシュボード - DC資産管理</PageTitle>

<MudText Typo="Typo.h3" Class="mb-6">ダッシュボード</MudText>

<MudGrid>
    <MudItem xs="12" sm="6" md="4">
        <MudPaper Elevation="2" Class="pa-4" Style="height: 200px;">
            <MudText Typo="Typo.h6">総資産評価額</MudText>
            <MudText Typo="Typo.h3" Color="Color.Primary" Class="mt-4">¥4,250,000</MudText>
            <MudText Typo="Typo.body2" Class="mt-2" Color="Color.Success">+¥120,000 (前月比)</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="6" md="4">
        <MudPaper Elevation="2" Class="pa-4" Style="height: 200px;">
            <MudText Typo="Typo.h6">評価損益</MudText>
            <MudText Typo="Typo.h3" Color="Color.Secondary" Class="mt-4">+¥850,000</MudText>
            <MudText Typo="Typo.body2" Class="mt-2">+25.0% (通算累計)</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="6" md="4">
        <MudPaper Elevation="2" Class="pa-4" Style="height: 200px;">
            <MudText Typo="Typo.h6">次回更新予定</MudText>
            <MudText Typo="Typo.h3" Class="mt-4">明日</MudText>
            <MudText Typo="Typo.body2" Class="mt-2">03:00 AM に実行予定</MudText>
        </MudPaper>
    </MudItem>

    <MudItem xs="12" md="8">
        <MudPaper Elevation="2" Class="pa-4">
            <MudText Typo="Typo.h6" Class="mb-4">資産推移</MudText>
            <MudChart T="double" ChartType="ChartType.Line" ChartSeries="@_series" XAxisLabels="@_xAxisLabels" Width="100%" Height="350px" />
        </MudPaper>
    </MudItem>
    <MudItem xs="12" md="4">
        <MudPaper Elevation="2" Class="pa-4">
            <MudText Typo="Typo.h6" Class="mb-4">ポートフォリオ構成</MudText>
            <MudChart T="double" ChartType="ChartType.Donut" Data="@_donutData" Labels="@_donutLabels" Width="100%" Height="300px" />
        </MudPaper>
    </MudItem>

    <MudItem xs="12">
        <MudPaper Elevation="2" Class="pa-4">
            <div class="d-flex align-center justify-space-between mb-4">
                <MudText Typo="Typo.h6">スクレイピング実行履歴</MudText>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.PlayArrow" OnClick="RunScraping">
                    今すぐ実行
                </MudButton>
            </div>
            <MudDataGrid Items="@_logs" Hover="true" Bordered="false" Striped="true" FixedHeader="true" Height="300px">
                <Columns>
                    <PropertyColumn Property="x => x.Target" Title="対象" />
                    <TemplateColumn Title="ステータス">
                        <CellTemplate>
                            <MudChip T="string" Color="@GetStatusColor(context.Item.Status)" Size="Size.Small" Variant="Variant.Text">
                                @(context.Item.Status == "Success" ? "成功" : context.Item.Status == "Error" ? "エラー" : context.Item.Status)
                            </MudChip>
                        </CellTemplate>
                    </TemplateColumn>
                    <PropertyColumn Property="x => x.StartedAt" Title="開始日時" Format="yyyy-MM-dd HH:mm" />
                    <PropertyColumn Property="x => x.FinishedAt" Title="終了日時" Format="yyyy-MM-dd HH:mm" />
                    <TemplateColumn Title="操作" CellClass="d-flex justify-end">
                        <CellTemplate>
                            <MudIconButton Icon="@Icons.Material.Filled.Info" Size="Size.Small" />
                        </CellTemplate>
                    </TemplateColumn>
                </Columns>
            </MudDataGrid>
        </MudPaper>
    </MudItem>

    <MudItem xs="12">
        <MudPaper Elevation="2" Class="pa-4">
            <MudText Typo="Typo.h6" Class="mb-4">保有銘柄一覧</MudText>
            <MudSimpleTable Style="overflow-x: auto;">
                <thead>
                    <tr>
                        <th>ファンド名</th>
                        <th>資産区分</th>
                        <th>評価金額</th>
                        <th>評価損益</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>Global Equity Fund</td>
                        <td>Equity</td>
                        <td>¥2,100,000</td>
                        <td><MudText Color="Color.Success">+¥450,000</MudText></td>
                    </tr>
                    <tr>
                        <td>Japan Debt Fund</td>
                        <td>Bond</td>
                        <td>¥1,200,000</td>
                        <td><MudText Color="Color.Error">-¥12,000</MudText></td>
                    </tr>
                    <tr>
                        <td>REIT Balanced</td>
                        <td>Real Estate</td>
                        <td>¥950,000</td>
                        <td><MudText Color="Color.Success">+¥85,000</MudText></td>
                    </tr>
                </tbody>
            </MudSimpleTable>
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    private List<ChartSeries<double>> _series = new List<ChartSeries<double>>()
    {
        new ChartSeries<double>() { Name = "資産残高", Data = new double[] { 3500000, 3620000, 3750000, 3810000, 4050000, 4250000 } }
    };
    private string[] _xAxisLabels = { "1月", "2月", "3月", "4月", "5月", "6月" };

    private double[] _donutData = { 50, 25, 25 };
    private string[] _donutLabels = { "株式", "債券", "リート・その他" };

    private List<ScrapingLogSummary> _logs = new()
    {
        new ScrapingLogSummary { Target = "UFJ DC Asset", Status = "Success", StartedAt = DateTime.Now.AddDays(-1), FinishedAt = DateTime.Now.AddDays(-1).AddMinutes(2) },
        new ScrapingLogSummary { Target = "UFJ DC Asset", Status = "Error", StartedAt = DateTime.Now.AddDays(-2), FinishedAt = DateTime.Now.AddDays(-2).AddMinutes(1) },
        new ScrapingLogSummary { Target = "UFJ DC Asset", Status = "Success", StartedAt = DateTime.Now.AddDays(-3), FinishedAt = DateTime.Now.AddDays(-3).AddMinutes(2) }
    };

    private Color GetStatusColor(string status) => status switch
    {
        "Success" => Color.Success,
        "Error" => Color.Error,
        "Running" => Color.Info,
        _ => Color.Default
    };

    private void RunScraping()
    {
        // 実際のトリガーは API を介して行うが、UIプロトタイプとしてメッセージを表示
    }

    public class ScrapingLogSummary
    {
        public string Target { get; set; } = string.Empty;
        public string Status { get; set; } = string.Empty;
        public DateTime StartedAt { get; set; }
        public DateTime? FinishedAt { get; set; }
    }
}
