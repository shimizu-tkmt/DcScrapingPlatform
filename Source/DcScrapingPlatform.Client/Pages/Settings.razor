@page "/settings"
@using MudBlazor
@layout MainLayout

<PageTitle>設定 - DC資産管理</PageTitle>

<MudText Typo="Typo.h3" Class="mb-6">設定</MudText>

<MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-6">
    <MudTabPanel Text="プロフィール設定" Icon="@Icons.Material.Filled.Person">
        <MudGrid>
            <MudItem xs="12" md="6">
                <MudTextField @bind-Value="_username" Label="ユーザー名" Variant="Variant.Outlined" Class="mb-4" />
                <MudTextField @bind-Value="_email" Label="メールアドレス" Variant="Variant.Outlined" Class="mb-4" />
                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Save">プロフィール更新</MudButton>
            </MudItem>
            <MudItem xs="12" md="6">
                <MudPaper Class="pa-4 bg-light shadow-none border-dashed" Style="border: 2px dashed #e0e0e0;">
                    <MudText Typo="Typo.body2" Color="Color.Info">
                        登録情報は最小限に保たれています。電話番号や住所等の情報は収集しません。
                    </MudText>
                </MudPaper>
            </MudItem>
        </MudGrid>
    </MudTabPanel>
    <MudTabPanel Text="DC連携設定" Icon="@Icons.Material.Filled.Security">
        <MudGrid>
            <MudItem xs="12" md="6">
                <MudText Typo="Typo.h6" Class="mb-4">Google スプレッドシート連携</MudText>
                <MudTextField @bind-Value="_spreadsheetId" Label="スプレッドシートID" Variant="Variant.Outlined" HelperText="GoogleスプレッドシートのURL等からIDを入力してください" Class="mb-4" />
                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Save">スプレッドシート設定を保存</MudButton>
            </MudItem>

            <MudItem xs="12" md="6">
                <MudText Typo="Typo.h6" Class="mb-4">確定拠出年金ログイン情報 (三菱UFJ信託)</MudText>
                <MudAlert Severity="Severity.Info" Class="mb-4">ログイン情報は AES-256 で暗号化された上でセキュアに保管されます。</MudAlert>
                <MudTextField @bind-Value="_ufjId" Label="ログインID" Variant="Variant.Outlined" Class="mb-4" />
                <MudTextField @bind-Value="_ufjPassword" Label="パスワード" Variant="Variant.Outlined" InputType="InputType.Password" Class="mb-4" />
                <MudButton Variant="Variant.Filled" Color="Color.Secondary" StartIcon="@Icons.Material.Filled.Security">暗号化して保存</MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Info" Class="ml-2" StartIcon="@Icons.Material.Filled.PlayArrow">接続テスト</MudButton>
            </MudItem>
        </MudGrid>
    </MudTabPanel>
    <MudTabPanel Text="危険ゾーン" Icon="@Icons.Material.Filled.Warning" Color="Color.Error">
        <MudPaper Class="pa-4 border-solid border-2 mud-border-error">
            <MudText Typo="Typo.h6" Color="Color.Error">アカウント削除</MudText>
            <MudText Typo="Typo.body2" Class="mb-4">アカウントを削除すると、すべてのデータが完全に消失し、復旧することはできません。</MudText>
            <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="OnDeleteAccount">アカウントを削除する</MudButton>
        </MudPaper>
    </MudTabPanel>
</MudTabs>

@code {
    private string _username = "Sample User";
    private string _email = "user@example.com";
    private string _spreadsheetId = string.Empty;
    private string _ufjId = string.Empty;
    private string _ufjPassword = string.Empty;

    private void OnDeleteAccount()
    {
        // 削除確認ダイアログ等の実装
    }
}
